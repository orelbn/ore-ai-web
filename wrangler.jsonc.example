/**
 * Template Wrangler config tracked in git.
 * Copy to wrangler.jsonc for local use and replace account-specific values.
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ore-ai",
	"main": "./src/server.ts",
	"workers_dev": false,
	"routes": [
		{
			"pattern": "replace-with-your-domain.example.com",
			"custom_domain": true
		}
	],
	"compatibility_date": "2026-02-25",
	"compatibility_flags": ["nodejs_compat"],
	"services": [
		{
			"binding": "ORE_AI_MCP",
			"service": "ore-ai-mcp"
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "replace-with-your-database-name",
			"database_id": "00000000-0000-0000-0000-000000000000"
		}
	],
	"ratelimits": [
		{
			"name": "CHAT_USER_QUOTA",
			"namespace_id": "000000000",
			"simple": {
				"limit": 12,
				"period": 60
			}
		},
		{
			"name": "CHAT_IP_QUOTA",
			"namespace_id": "000000001",
			"simple": {
				"limit": 30,
				"period": 60
			}
		}
	],
	"r2_buckets": [
		{
			"binding": "AGENT_PROMPTS",
			"bucket_name": "replace-with-your-agent-prompts-bucket-name"
		}
	],
	"observability": {
		"enabled": true
	},
	"vars": {
		"TURNSTILE_SITE_KEY": "replace-with-your-turnstile-site-key"
	},
	"env": {
		"production": {
			"services": [
				{
					"binding": "ORE_AI_MCP",
					"service": "ore-ai-mcp",
					"remote": true
				}
			],
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "replace-with-your-production-database-name",
					"database_id": "00000000-0000-0000-0000-000000000000"
				}
			],
			"ratelimits": [
				{
					"name": "CHAT_USER_QUOTA",
					"namespace_id": "000000000",
					"simple": {
						"limit": 12,
						"period": 60
					}
				},
				{
					"name": "CHAT_IP_QUOTA",
					"namespace_id": "000000001",
					"simple": {
						"limit": 30,
						"period": 60
					}
				}
			],
			"r2_buckets": [
				{
					"binding": "AGENT_PROMPTS",
					"bucket_name": "replace-with-your-production-agent-prompts-bucket-name",
					"remote": true
				}
			],
			"vars": {
				"TURNSTILE_SITE_KEY": "replace-with-your-turnstile-site-key"
			}
		}
	}
}
