/**
 * Template Wrangler config tracked in git.
 * Copy to wrangler.jsonc for local use and replace account-specific values.
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ore-ai",
	"main": "./src/server.ts",
	"workers_dev": false,
	"routes": [
		{
			"pattern": "replace-with-your-domain.example.com",
			"custom_domain": true
		}
	],
	"compatibility_date": "2026-02-25",
	"compatibility_flags": ["nodejs_compat"],
	"durable_objects": {
		"bindings": [
			{
				"name": "RATE_LIMITER",
				"class_name": "RateLimiterDurableObject"
			}
		]
	},
	"services": [
		{
			"binding": "ORE_AI_MCP",
			"service": "replace-with-your-mcp-worker-name",
			"remote": true
		}
	],
	"r2_buckets": [
		{
			"binding": "AGENT_PROMPTS",
			"bucket_name": "replace-with-your-agent-prompts-bucket-name",
			"remote": true
		}
	],
	"observability": {
		"enabled": true
	},
	"migrations": [
		{
			"tag": "v1-rate-limiter",
			"new_sqlite_classes": ["RateLimiterDurableObject"]
		}
	],
	"vars": {
		"TURNSTILE_SITE_KEY": "replace-with-your-turnstile-site-key"
	},
	"env": {
		"production": {
			"durable_objects": {
				"bindings": [
					{
						"name": "RATE_LIMITER",
						"class_name": "RateLimiterDurableObject"
					}
				]
			},
			"services": [
				{
					"binding": "ORE_AI_MCP",
					"service": "replace-with-your-mcp-worker-name",
					"remote": true
				}
			],
			"r2_buckets": [
				{
					"binding": "AGENT_PROMPTS",
					"bucket_name": "replace-with-your-production-agent-prompts-bucket-name",
					"remote": true
				}
			],
			"vars": {
				"TURNSTILE_SITE_KEY": "replace-with-your-turnstile-site-key"
			}
		}
	}
}
