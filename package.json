{
	"name": "ore-ai-web",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build && tsgo --noEmit",
		"preview": "vite preview --port 3000",
		"typecheck": "tsgo --noEmit",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "bun test ./src",
		"evals": "bun --no-env-file --env-file=.env.evals test ./evals/tests",
		"deploy": "bun run build && wrangler deploy --config wrangler.jsonc",
		"cf-typegen": "wrangler types --config wrangler.jsonc --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"prompt:upload": "bun ./scripts/upload-agent-prompt.ts",
		"auth:generate": "bunx @better-auth/cli generate --output src/db/schema/auth.ts -y",
		"db:generate": "bunx drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply ore-ai --local --config wrangler.jsonc",
		"db:migrate:prod": "wrangler d1 migrations apply ore-ai --remote --config wrangler.jsonc"
	},
	"dependencies": {
		"@ai-sdk/mcp": "^1.0.23",
		"@ai-sdk/react": "^3.0.113",
		"@base-ui/react": "^1.2.0",
		"@fontsource-variable/geist": "^5.2.8",
		"@hugeicons/core-free-icons": "^3.3.0",
		"@hugeicons/react": "^1.1.5",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.163.3",
		"@tanstack/react-start": "^1.166.1",
		"@tanstack/router-plugin": "^1.164.0",
		"ai": "^6.0.111",
		"better-auth": "^1.5.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.5.0",
		"workers-ai-provider": "^3.1.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@typescript/native-preview": "^7.0.0-dev.20260303.1",
		"@biomejs/biome": "2.4.5",
		"@cloudflare/vite-plugin": "^1.26.0",
		"@tailwindcss/vite": "^4.2.1",
		"@types/bun": "^1.3.10",
		"@types/node": "^25.3.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"babel-plugin-react-compiler": "^1.0.0",
		"drizzle-kit": "^0.31.9",
		"shadcn": "^3.8.5",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"vite": "^7.3.1",
		"vite-tsconfig-paths": "^6.1.1",
		"wrangler": "^4.70.0"
	}
}
