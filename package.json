{
	"name": "ore-ai-web",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"hooks:install": "git config core.hooksPath .githooks",
		"build": "vite build && tsgo --noEmit",
		"preview": "vite preview --port 3000",
		"typecheck": "tsgo --noEmit",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"evals": "bun --no-env-file --env-file=.dev.vars test --timeout=30000 ./evals/tests",
		"deploy": "bun run build && wrangler deploy --config dist/server/wrangler.json",
		"deploy:dry-run": "bun run build && wrangler deploy --dry-run --config dist/server/wrangler.json",
		"cf-typegen": "wrangler types --config wrangler.jsonc --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"prompt:upload": "bun ./scripts/upload-agent-prompt.ts"
	},
	"dependencies": {
		"@ai-sdk/google": "^3.0.43",
		"@ai-sdk/mcp": "^1.0.25",
		"@ai-sdk/react": "^3.0.118",
		"@base-ui/react": "^1.3.0",
		"@fontsource-variable/geist": "^5.2.8",
		"@hugeicons/core-free-icons": "^4.0.0",
		"@hugeicons/react": "^1.1.6",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.166.8",
		"@tanstack/react-start": "^1.166.9",
		"@tanstack/router-plugin": "^1.166.8",
		"ai": "^6.0.116",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@biomejs/biome": "2.4.7",
		"@cloudflare/vite-plugin": "^1.28.0",
		"@rolldown/plugin-babel": "^0.2.1",
		"@tailwindcss/vite": "^4.2.1",
		"@types/bun": "^1.3.10",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260313.1",
		"@vitejs/plugin-react": "^6.0.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"shadcn": "^4.0.6",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"vite": "^8.0.0",
		"vitest": "^4.1.0",
		"wrangler": "^4.73.0"
	}
}
