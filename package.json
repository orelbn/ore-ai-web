{
	"name": "ore-ai-web",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"prepare": "node .husky/install.mjs",
		"build": "vite build && tsgo --noEmit",
		"preview": "vite preview --port 3000",
		"typecheck": "tsgo --noEmit",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"evals": "bun --no-env-file --env-file=.dev.vars test --timeout=30000 ./evals/tests",
		"deploy": "bun run build && wrangler deploy --config dist/server/wrangler.json",
		"deploy:dry-run": "bun run build && wrangler deploy --dry-run --config dist/server/wrangler.json",
		"cf-typegen": "wrangler types --config wrangler.jsonc --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"prompt:upload": "bun ./scripts/upload-agent-prompt.ts"
	},
	"dependencies": {
		"@ai-sdk/google": "^3.0.53",
		"@ai-sdk/mcp": "^1.0.30",
		"@ai-sdk/react": "^3.0.139",
		"@base-ui/react": "^1.3.0",
		"@fontsource-variable/inter": "^5.2.8",
		"@marsidev/react-turnstile": "^1.4.2",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@tanstack/react-query": "^5.95.2",
		"@tanstack/react-router": "^1.168.3",
		"@tanstack/react-start": "^1.167.5",
		"@tanstack/router-plugin": "^1.167.4",
		"ai": "^6.0.137",
		"better-auth": "^1.5.6",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.1",
		"lucide-react": "^1.7.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@biomejs/biome": "2.4.8",
		"@cloudflare/vite-plugin": "^1.30.0",
		"@cloudflare/vitest-pool-workers": "^0.13.4",
		"@rolldown/plugin-babel": "^0.2.2",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "^1.3.11",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260323.1",
		"@vitejs/plugin-react": "^6.0.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"drizzle-kit": "^0.31.10",
		"husky": "^9.1.7",
		"shadcn": "^4.1.0",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"vite": "^8.0.2",
		"vitest": "^4.1.1",
		"wrangler": "^4.76.0"
	}
}
